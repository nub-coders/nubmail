# =============================================================================
# NubMail environment configuration
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Generate strong random secrets with:  openssl rand -base64 32
# =============================================================================

# --- App ---------------------------------------------------------------------
PORT=5000
NODE_ENV=production
# Public base URL of the web app (used for SEO metadata / OpenGraph).
NEXT_PUBLIC_SITE_URL=https://mail.example.com
# http or https
PROTOCOL=https

# --- Domain / host -----------------------------------------------------------
# Apex domain this server sends mail for.
DOMAIN=example.com
# Public hostname of the mail server (A record + TLS cert CN).
HOST=mail.example.com

# --- Auth / crypto secrets (REQUIRED — generate unique random values) --------
# Signs session JWTs.
JWT_SECRET=change-me-openssl-rand-base64-32
# Encrypts stored user API keys (AES-256-GCM).
API_KEY_ENCRYPTION_SECRET=change-me-openssl-rand-base64-32
# Encrypts sensitive DB fields (e.g. DKIM private keys).
FIELD_ENCRYPTION_SECRET=change-me-openssl-rand-base64-32
# Encrypts database backups produced by scripts/backup-pg.sh.
BACKUP_ENCRYPTION_KEY=change-me-openssl-rand-base64-32

# --- Initial admin user (seeded on first start) ------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me-strong-password

# --- Database ----------------------------------------------------------------
USE_POSTGRES=true
# Password for the bundled Postgres container (see docker-compose.yml).
POSTGRES_PASSWORD=change-me-strong-password
# Connection string used by the app. When using the bundled container the host
# is the compose service alias `nubmail-db`.
POSTGRES_URL=postgresql://nubmail:change-me-strong-password@nubmail-db:5432/nubmail

# --- Outbound SMTP (relay used to send mail) ---------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Internal relay used by app -> bundled Postfix container (usually unchanged).
INTERNAL_SMTP_HOST=smtp-sender
INTERNAL_SMTP_PORT=587

# --- Inbound SMTP receiver (bundled Node MX on port 25) ----------------------
# Domains this MX will accept mail for. Leave blank to rely on verified-domain
# account checks (comma-separated, e.g. example.com,mail.example.com).
INBOUND_ALLOWED_DOMAINS=
# STARTTLS certs for the receiver. Defaults point at the certs dumped by
# traefik-certs-dumper; leave as-is unless certs live elsewhere. If the files
# are absent, the receiver runs cleartext-only (STARTTLS simply not advertised).
SMTP_TLS_CERT=/etc/ssl/mail/fullchain.pem
SMTP_TLS_KEY=/etc/ssl/mail/key.pem
# Per-IP connection rate limiting (guards against floods / DoS).
SMTP_MAX_CONNECTIONS_PER_IP=10
SMTP_CONN_RATE_LIMIT=30
SMTP_CONN_RATE_WINDOW_MS=60000

# --- DKIM --------------------------------------------------------------------
# Selector for the server-level DKIM key.
SERVER_DKIM_PRIVATE_SELECTOR=default

# --- Web Push (VAPID) — optional; leave blank to disable push notifications ---
# Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- TLS certificates --------------------------------------------------------
# Directory containing per-host Let's Encrypt certs (bind-mounted into Dovecot
# and Postfix as ${CERTS_DIR}/${HOST}/fullchain.pem + key.pem).
CERTS_DIR=./certs
# Override if certs are managed by an external nginx-proxy / acme-companion.
# NGINX_CERTS_DIR=/path/to/nginx-proxy/certs
