/**
 * @fileoverview Firestore Security Rules for NubMail.
 *
 * Core Philosophy: This ruleset enforces a strict user-ownership model for all data. Users can only access their own data, and no global roles or shared access patterns are implemented.
 *
 * Data Structure: All data is nested under /users/{userId}, creating a clear hierarchy of ownership.
 * - /users/{userId}: User profile data.
 * - /users/{userId}/domains/{domainId}: Domain data owned by the user.
 * - /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId}: Email account data owned by the user and domain.
 * - /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId}/emailMessages/{emailMessageId}: Email message data owned by the user, domain, and email account.
 * - /users/{userId}/activityLogs/{activityLogId}: Activity logs for the user.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - No global admin roles are defined.
 * - All write operations are restricted to the owner of the data.
 * - The rules prioritize authorization and do not implement strict schema validation.
 *
 * Denormalization for Authorization: The data structure denormalizes ownership through the path. This avoids the need for costly `get()` calls to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces path-based ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create their own profile at /users/user_abc.
     * @allow (get, update, delete) - Authenticated user with UID 'user_abc' can read, update, or delete their own profile at /users/user_abc.
     * @deny (create, get, update, delete) - Authenticated user with UID 'user_xyz' cannot create, read, update, or delete the profile at /users/user_abc.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId) && resource.data.id == userId;
      allow delete: if isSignedIn() && isOwner(userId) && resource.data.id == userId;
    }

    /**
     * @description Enforces path-based ownership for domains within a user's profile.
     * @path /users/{userId}/domains/{domainId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a domain under their profile at /users/user_abc/domains/domain_123.
     * @allow (get, update, delete) - Authenticated user with UID 'user_abc' can read, update, or delete a domain under their profile at /users/user_abc/domains/domain_123.
     * @deny (create, get, update, delete) - Authenticated user with UID 'user_xyz' cannot create, read, update, or delete a domain under /users/user_abc/domains/domain_123.
     * @principle Enforces document ownership for all operations on domains.
     */
    match /users/{userId}/domains/{domainId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces path-based ownership for email accounts within a domain.
     * @path /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create an email account under their domain at /users/user_abc/domains/domain_123/emailAccounts/email_account_456.
     * @allow (get, update, delete) - Authenticated user with UID 'user_abc' can read, update, or delete an email account under their domain.
     * @deny (create, get, update, delete) - Authenticated user with UID 'user_xyz' cannot create, read, update, or delete an email account under /users/user_abc/domains/domain_123/emailAccounts/email_account_456.
     * @principle Enforces document ownership for all operations on email accounts.
     */
    match /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces path-based ownership for email messages within an email account.
     * @path /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId}/emailMessages/{emailMessageId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create an email message under their email account.
     * @allow (get, update, delete) - Authenticated user with UID 'user_abc' can read, update, or delete an email message under their email account.
     * @deny (create, get, update, delete) - Authenticated user with UID 'user_xyz' cannot create, read, update, or delete an email message under another user's email account.
     * @principle Enforces document ownership for all operations on email messages.
     */
    match /users/{userId}/domains/{domainId}/emailAccounts/{emailAccountId}/emailMessages/{emailMessageId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces path-based ownership for activity logs within a user's profile.
     * @path /users/{userId}/activityLogs/{activityLogId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create an activity log under their profile at /users/user_abc/activityLogs/log_789.
     * @allow (get, update, delete) - Authenticated user with UID 'user_abc' can read, update, or delete an activity log under their profile.
     * @deny (create, get, update, delete) - Authenticated user with UID 'user_xyz' cannot create, read, update, or delete an activity log under /users/user_abc/activityLogs/log_789.
     * @principle Enforces document ownership for all operations on activity logs.
     */
    match /users/{userId}/activityLogs/{activityLogId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
       function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}