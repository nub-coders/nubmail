driver = pgsql
connect = host=postgres dbname=nubmail user=nubmail password=nubmail

# Query to fetch email account credentials (not user login credentials)
# Users authenticate with their email_address and email account password
# Use full email address with @ replaced by underscore for directory naming
user_query = SELECT email_address as user, '/app/maildata/' || replace(email_address, '@', '_at_') || '/Maildir' as home, 'maildir:/app/maildata/' || replace(email_address, '@', '_at_') || '/Maildir' as mail, 1000 AS uid, 1000 AS gid FROM email_accounts WHERE email_address = '%u'
password_query = SELECT email_address as user, password_hash as password, '/app/maildata/' || replace(email_address, '@', '_at_') || '/Maildir' as userdb_home, 'maildir:/app/maildata/' || replace(email_address, '@', '_at_') || '/Maildir' as userdb_mail, 1000 AS userdb_uid, 1000 AS userdb_gid FROM email_accounts WHERE email_address = '%u' AND password_hash IS NOT NULL
